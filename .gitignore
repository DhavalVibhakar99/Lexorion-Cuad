# macOS
.DS_Store

# Python cache and build artifacts
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Virtual environments
venv/
.venv/
env/

# Local environment variables and secrets (broad glob catches stray copies)
.env*
!.env.example
.streamlit/secrets.toml

# Jupyter
.ipynb_checkpoints/

# Editor history/backups
.history/

# Data and model artifacts
data/raw/
data/processed/
data/evaluation/
# Keep the small baseline artifact so the deployed dashboard can score live
checkpoints/*
!checkpoints/baseline_tfidf_logreg.joblib

# LLM/API caches
llm_cache/
data/processed/llm_cache/

# Logs
*.log

# Local agent tooling
.claude/
